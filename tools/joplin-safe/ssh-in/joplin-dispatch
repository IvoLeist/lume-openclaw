#!/usr/bin/env bash
set -euo pipefail

RAW_CMD="${SSH_ORIGINAL_COMMAND:-}"

echo "Received command: $RAW_CMD" >&2

if [ -z "$RAW_CMD" ]; then
  echo "❌ No command provided" >&2
  exit 1
fi

case "$RAW_CMD" in
  list-notes)
    exec python /app/joplin_api_wrapper.py list-notes
    ;;
  create-note\ *)
    PAYLOAD="${RAW_CMD#create-note }"
    TITLE="${PAYLOAD%% *}"
    BODY="${PAYLOAD#* }"

    if [ -z "$PAYLOAD" ] || [ "$PAYLOAD" = "$TITLE" ] || [ -z "$TITLE" ] || [ -z "$BODY" ]; then
      echo "❌ create-note requires a title and a body" >&2
      echo "Usage: create-note <title> <body>" >&2
      exit 1
    fi

    exec python /app/joplin_api_wrapper.py create-note "$TITLE" "$BODY"
    ;;
  *)
    echo "❌ Command not allowed" >&2
    exit 1
    ;;
esac