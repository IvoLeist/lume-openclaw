#!/usr/bin/env bash
set -euo pipefail

RAW_CMD="${SSH_ORIGINAL_COMMAND:-}"

echo "Received command: $RAW_CMD" >&2

if [ -z "$RAW_CMD" ]; then
  echo "❌ No command provided" >&2
  exit 1
fi

case "$RAW_CMD" in
  list-notes)
    exec python /app/joplin_api_wrapper.py list-notes
    ;;
  create-note\ *)
    TITLE="${RAW_CMD#create-note }"
    if [ -z "$TITLE" ]; then
      echo "❌ create-note requires a title" >&2
      exit 1
    fi
    exec python /app/joplin_api_wrapper.py create-note "$TITLE"
    ;;
  *)
    echo "❌ Command not allowed" >&2
    exit 1
    ;;
esac