    "vm:launch": "./scripts/vm/launch-vm-and-gateway.sh",
    "gateway": "./scripts/openclaw/openclaw-gateway.sh",
    "tui": "./scripts/openclaw/openclaw-tui.sh",
    "ssh": "./scripts/connect/ssh-vm.sh",
