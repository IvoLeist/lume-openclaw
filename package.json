  "description": "Run OpenClaw (Clawdbot) inside a Lume macOS VM. Scripts and docs for host-side control.",
  "private": true,
  "scripts": {
    "vm:install": "./scripts/vm/install-lume.sh",
    "vm:create": "./scripts/vm/create-openclaw-vm.sh",
    "vm:start": "./scripts/vm/start-vm.sh",
